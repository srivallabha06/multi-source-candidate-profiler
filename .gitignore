# pyenv
#   For a library or app, you might want to share your .python-version if you're
#   using pyenv. However, for a project, it's often user-specific:
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different platforms or sub-versions, lockfile conflicts might arise.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains specific versions, but may raise conflict.
# poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock contains specific versions
# pdm.lock

# virtualenv
#   It's strongly recommended to exclude virtual environments from git
.venv/
venv/
ENV/
env/
active_env/

